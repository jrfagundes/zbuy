# Copie para apps/mobile/.env e preencha.

# URL da API.
# - Emulador Android: NÃO defina (usa o default http://10.0.2.2:3001)
# - Dispositivo físico (Expo Go / dev client): use o IP da sua máquina na LAN
#   EXPO_PUBLIC_API_URL=http://192.168.1.X:3001

# Login com Google — Web OAuth Client ID do Google Cloud Console.
# O MESMO valor deve estar em GOOGLE_CLIENT_ID no .env raiz (backend).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=SEU_WEB_CLIENT_ID.apps.googleusercontent.com
